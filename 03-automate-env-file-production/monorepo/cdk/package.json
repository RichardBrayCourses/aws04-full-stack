{
  "name": "@root/cdk",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "cdk:deploy:cloudfront": "cdk deploy cloudfront-website --require-approval never --app 'tsx ./src/bin/cloudfront.ts'",
    "cdk:destroy:cloudfront": "cdk destroy cloudfront-website --force --require-approval never --app 'tsx ./src/bin/cloudfront.ts'",
    "cdk:deploy:api": "cdk deploy api-service --require-approval never --app 'tsx ./src/bin/api.ts'",
    "cdk:destroy:api": "cdk destroy api-service --force --require-approval never --app 'tsx ./src/bin/api.ts'",
    "type-check": "tsc --noEmit",
    "package-cleanup": "rm -rf node_modules cdk.out"
  },
  "dependencies": {
    "aws-cdk-lib": "2.235.1",
    "constructs": "10.4.5"
  },
  "devDependencies": {
    "@types/node": "^25.3.1",
    "esbuild": "0.27.7",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
